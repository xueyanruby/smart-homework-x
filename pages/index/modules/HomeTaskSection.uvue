<template>
  <view class="section">
    <view class="section__toolbar">
      <!-- #ifdef MP-WEIXIN -->
      <snapshot id="hw-section-snapshot" mode="view" class="section__snapshot">
      <!-- #endif -->
        <view id="hw-section-capture" class="section__capture">
          <view class="section__head">
            <text class="section__title">{{ sectionTitle }}</text>
          </view>

          <view v-for="task in tasks" :key="task.key" class="task-card">
          <view
            class="task-card__body"
            :class="task.muted ? 'task-card__body--muted' : ''"
            @click="emit('opentask', task.taskId, task.occurrenceDayKey)"
          >
            <view class="task-title-row">
              <view class="tag" :class="tagClassForSubject(task.subjectKind)">
                <text class="tag__text" :class="tagTextClassForSubject(task.subjectKind)">{{ task.subject }}</text>
              </view>
              <text class="task-title" :class="task.titleDone ? 'task-title--done' : ''">{{ task.title }}</text>
            </view>
            <view class="task-due-block">
              <view class="due-block">
                <view v-if="task.dueRangeMain != null && task.dueRangeMain.length > 0" class="due-row">
                  <view class="due-row__icon-wrap">
                    <uni-icons type="calendar" size="28rpx" color="#5a6157" />
                  </view>
                  <text class="due-row__text">{{ task.dueRangeMain }}</text>
                </view>
                <view
                  v-if="task.dueRangeSub != null && task.dueRangeSub.length > 0"
                  class="due-sub-row"
                >
                  <text class="due-row__text due-sub-row__text">{{ task.dueRangeSub }}</text>
                </view>
              </view>
            </view>
          </view>

          <view v-if="task.trailing == 'complete'" class="btn-primary-sm" @click.stop="emit('complete', task.taskId, task.occurrenceDayKey)">
            <text class="btn-primary-sm__text">完成</text>
          </view>
          <view v-else class="pill-done" @click.stop="emit('uncomplete', task.taskId, task.occurrenceDayKey)">
            <text class="pill-done__text">已完成</text>
          </view>
          </view>
        </view>
      <!-- #ifdef MP-WEIXIN -->
      </snapshot>
      <!-- #endif -->

      <view v-if="tasks.length > 0" class="section__menu-hit" @tap.stop="onMenuTap">
        <uni-icons type="more-filled" size="40rpx" color="#3e6942" />
      </view>
    </view>
  </view>
</template>

<script setup>
  import { getCurrentInstance } from 'vue'

  defineProps({
    sectionTitle: { type: String, default: '' },
    tasks: { type: Array, default: () => [] },
  })

  const emit = defineEmits(['complete', 'uncomplete', 'opentask', 'save', 'share'])

  const selfProxy = getCurrentInstance()?.proxy

  const onMenuTap = () => {
    uni.showActionSheet({
      itemList: ['保存', '分享'],
      success: (res) => {
        const idx = res.tapIndex
        if (idx == 0) {
          emit('save')
        } else if (idx == 1) {
          emit('share')
        }
      },
      fail: () => {},
    })
  }

  // #ifdef MP-WEIXIN
  /**
   * 在组件自身作用域内执行 SelectorQuery，可找到本组件 shadow DOM 内的 snapshot 节点。
   * 由页面通过 ref 调用，避免页面级 query 跨 shadow DOM 找不到节点的问题。
   */
  const takeSkylineCapture = (onFinish : (ok : boolean, filePath : string) => void) => {
    console.log('[snapshot] takeSkylineCapture called, selfProxy:', selfProxy != null)
    const query = uni.createSelectorQuery()
    const scoped = selfProxy != null ? query.in(selfProxy) : query
    scoped.select('#hw-section-snapshot').node().exec((res : any) => {
      console.log('[snapshot] exec res:', JSON.stringify(res))
      if (res == null) {
        console.warn('[snapshot] exec res null')
        onFinish(false, '')
        return
      }
      const arr = res as any[]
      if (arr.length == 0) {
        console.warn('[snapshot] exec arr empty')
        onFinish(false, '')
        return
      }
      const item = arr[0] as UTSJSONObject
      if (item == null) {
        console.warn('[snapshot] arr[0] null')
        onFinish(false, '')
        return
      }
      const nodeVal = item['node']
      if (nodeVal == null) {
        console.warn('[snapshot] node null — snapshot 节点未找到')
        onFinish(false, '')
        return
      }
      const snapNode = nodeVal as UTSJSONObject
      const takeFn = snapNode['takeSnapshot']
      if (takeFn == null || typeof takeFn != 'function') {
        console.warn('[snapshot] takeSnapshot not a function')
        onFinish(false, '')
        return
      }
      const invoke = takeFn as (options : UTSJSONObject) => void
      invoke({
        type: 'file',
        format: 'png',
        success: (snapRes : UTSJSONObject) => {
          const pathVal = snapRes['tempFilePath']
          const path = pathVal != null ? (pathVal as string) : ''
          console.log('[snapshot] takeSnapshot ok:', path)
          onFinish(path.length > 0, path)
        },
        fail: (err : any) => {
          console.warn('[snapshot] takeSnapshot fail', err)
          onFinish(false, '')
        },
      })
    })
  }

  defineExpose({ takeSkylineCapture })
  // #endif

  const tagClassForSubject = (kind : string) => {
    if (kind == 'math') {
      return 'tag--math'
    }
    if (kind == 'en') {
      return 'tag--en'
    }
    if (kind == 'zh') {
      return 'tag--zh'
    }
    return 'tag--custom'
  }

  const tagTextClassForSubject = (kind : string) => {
    if (kind == 'en') {
      return 'tag__text--en'
    }
    if (kind == 'zh') {
      return 'tag__text--zh'
    }
    if (kind == 'custom') {
      return 'tag__text--custom'
    }
    return ''
  }
</script>

<style scoped>
  .section {
    /* 水平 padding 移入 .section__capture，让 snapshot 截图包含左右边距 */
    padding-top: 8rpx;
  }

  .section__toolbar {
    position: relative;
  }

  .section__snapshot {
    width: 100%;
    background-color: #f8faf3;
  }

  .section__capture {
    width: 100%;
    padding-left: 40rpx;
    padding-right: 40rpx;
    padding-top: 16rpx;
    padding-bottom: 40rpx;
    box-sizing: border-box;
    background-color: #f8faf3;
  }

  .section__head {
    display: flex;
    flex-direction: row;
    align-items: center;
    padding-left: 4rpx;
    padding-right: 80rpx;
    margin-bottom: 32rpx;
  }

  .section__title {
    font-size: 40rpx;
    font-weight: 600;
    color: #2d342c;
  }

  .section__menu-hit {
    position: absolute;
    right: 44rpx;
    top: 16rpx;
    z-index: 2;
    display: flex;
    flex-direction: row;
