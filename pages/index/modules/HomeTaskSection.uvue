    justify-content: center;
    min-width: 72rpx;
    min-height: 72rpx;
    padding-left: 8rpx;
    padding-right: 8rpx;
    padding-top: 8rpx;
    padding-bottom: 8rpx;
    border-radius: 9999rpx;
  }

  .task-card {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 48rpx;
    padding: 32rpx;
    border-radius: 24rpx;
    border-width: 1px;
    border-style: solid;
    border-color: #adb4a8;
    background-color: #ffffff;
    box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  }

  .task-card__body {
    display: flex;
    flex: 1;
    flex-direction: column;
    margin-right: 24rpx;
    min-width: 0;
  }

  .task-card__body--muted {
    opacity: 0.6;
  }

  .task-title-row {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    column-gap: 16rpx;
    width: 100%;
  }

  .task-title {
    flex: 1;
    min-width: 0;
    font-size: 34rpx;
    line-height: 48rpx;
    font-weight: 500;
    color: #2d342c;
    overflow-wrap: break-word;
    word-break: break-word;
  }

  .task-title--done {
    text-decoration: line-through;
  }

  .task-due-block {
    display: flex;
    flex-direction: row;
    width: 100%;
    margin-top: 8rpx;
    min-width: 0;
  }

  .tag {
    flex-shrink: 0;
    align-self: flex-start;
    padding-left: 16rpx;
    padding-right: 16rpx;
    padding-top: 4rpx;
    padding-bottom: 4rpx;
    border-radius: 8rpx;
    margin-top: 4rpx;
    border-width: 0;
  }

  .tag--math {
    background-color: #e3f2e4;
  }

  .tag--en {
    background-color: #f4f7d0;
  }

  .tag--zh {
    background-color: #e8eef8;
  }

  .tag--custom {
    background-color: #ede4f7;
  }

  .tag__text {
    font-size: 22rpx;
    font-weight: 700;
    color: #3e6942;
  }

  .tag__text--en {
    color: #5d6330;
  }

  .tag__text--zh {
    color: #3d4f6b;
  }

  .tag__text--custom {
    color: #5a3d6b;
  }

  .due-block {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    flex: 1;
    width: 100%;
    min-width: 0;
  }

  .due-row {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    width: 100%;
    min-width: 0;
  }

  /* 设计稿：material-symbols-outlined text-[14px]；与文案 gap-1（4px） */
  .due-row__icon-wrap {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    margin-right: 8rpx;
    margin-top: 4rpx;
    flex-shrink: 0;
  }

  .due-sub-row {
    display: flex;
    flex-direction: row;
    margin-top: 0;
  }

  .due-row + .due-sub-row {
    margin-top: 4rpx;
  }

  /* 设计稿：text-caption text-on-surface-variant — 13px / 18px 行高 */
  .due-row__text {
    font-size: 26rpx;
    line-height: 36rpx;
    color: #5a6157;
    flex: 1;
    min-width: 0;
    /* 微信小程序 <text> 不会自动继承 flex 收缩换行，需显式声明 */
    word-break: break-word;
    overflow-wrap: break-word;
  }

  .due-sub-row__text {
    flex: none;
  }

  .btn-primary-sm {
    padding-left: 32rpx;
    padding-right: 32rpx;
    padding-top: 12rpx;
    padding-bottom: 12rpx;
    border-radius: 9999px;
    background-color: #3e6942;
    border-width: 0;
    box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
    box-sizing: border-box;
  }

  .btn-primary-sm__text {
    font-size: 28rpx;
    line-height: 40rpx;
    font-weight: 600;
    color: #e9ffe5;
  }

  .pill-done {
    padding-left: 24rpx;
    padding-right: 24rpx;
    padding-top: 12rpx;
    padding-bottom: 12rpx;
    border-radius: 9999px;
    background-color: #d4e8d0;
    border-width: 0;
    box-sizing: border-box;
  }

  .pill-done__text {
    font-size: 28rpx;
