    overflow: hidden;
    background-color: #ebefe5;
    border-width: 1px;
    border-style: solid;
    border-color: #adb4a8;
    box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  }

  .img-one {
    width: 100%;
    height: 100%;
  }

  .wrap-two {
    display: flex;
    flex-direction: row;
    width: 100%;
    height: 360rpx;
    justify-content: space-between;
  }

  .cell-two {
    width: 48%;
    height: 100%;
    border-radius: 16rpx;
    overflow: hidden;
    background-color: #ebefe5;
    border-width: 1px;
    border-style: solid;
    border-color: #adb4a8;
    box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  }

  .img-fill {
    width: 100%;
    height: 100%;
  }

  .grid {
    display: flex;
    flex-direction: row;
    width: 100%;
    height: 360rpx;
    justify-content: space-between;
  }

  .cell-left {
    width: 48%;
    height: 100%;
    border-radius: 16rpx;
    overflow: hidden;
    background-color: #ebefe5;
    border-width: 1px;
    border-style: solid;
    border-color: #adb4a8;
    box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  }

  .cell-right {
    width: 48%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .img {
    width: 100%;
    height: 100%;
  }

  .img--sq {
    width: 100%;
    height: 100%;
  }

  .img--top-wrap {
    width: 100%;
    height: 48%;
    margin-bottom: 24rpx;
    border-radius: 16rpx;
    overflow: hidden;
    background-color: #ebefe5;
    border-width: 1px;
    border-style: solid;
    border-color: #adb4a8;
    box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
    flex-shrink: 0;
  }

  .img--top {
    width: 100%;
    height: 100%;
  }

  .cell-b {
    position: relative;
    width: 100%;
    height: 48%;
    border-radius: 16rpx;
    overflow: hidden;
    background-color: #ebefe5;
