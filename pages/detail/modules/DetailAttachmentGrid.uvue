<template>
  <view v-if="images.length > 0" class="root">
    <text class="h3">附件 ({{ images.length }})</text>

    <view v-if="images.length == 1" class="wrap-one" @click="previewAt(0)">
      <image class="img-one" :src="safeSrc(0)" mode="aspectFill"></image>
    </view>

    <view v-else-if="images.length == 2" class="wrap-two">
      <view class="cell-two" @click="previewAt(0)">
        <image class="img-fill" :src="safeSrc(0)" mode="aspectFill"></image>
      </view>
      <view class="cell-two" @click="previewAt(1)">
        <image class="img-fill" :src="safeSrc(1)" mode="aspectFill"></image>
      </view>
    </view>

    <view v-else class="grid">
      <view class="cell-left" @click="previewAt(0)">
        <image class="img img--sq" :src="safeSrc(0)" mode="aspectFill"></image>
      </view>
      <view class="cell-right">
        <view class="img--top-wrap" @click="previewAt(1)">
          <image class="img img--top" :src="safeSrc(1)" mode="aspectFill"></image>
        </view>
        <view class="cell-b" @click="previewAt(2)">
          <image class="img img--blur" :src="safeSrc(2)" mode="aspectFill"></image>
          <view v-if="images.length > 3" class="overlay" @click.stop="previewAt(3)">
            <text class="overlay__txt">+{{ images.length - 3 }}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</template>

<script setup>
  const props = defineProps({
    images: { type: Array, default: () => [] },
  })

  const safeSrc = (idx : number) => {
    const arr = props.images as string[]
    if (arr == null || idx < 0 || idx >= arr.length) {
      return ''
    }
    return arr[idx]
  }

  const buildPreviewUrls = () : string[] => {
    const arr = props.images as string[]
    const out : string[] = []
    if (arr == null) {
      return out
    }
    for (let i = 0; i < arr.length; i++) {
      const s = arr[i] as string
      if (s != null && s.length > 0) {
        out.push(s)
      }
    }
    return out
  }

  const previewAt = (index : number) => {
    const urls = buildPreviewUrls()
    if (urls.length == 0) {
      return
    }
    let cur = safeSrc(index)
    if (cur.length == 0) {
      cur = urls[0]
    } else {
      let found = false
      for (let j = 0; j < urls.length; j++) {
        if (urls[j] == cur) {
          found = true
          break
        }
      }
      if (!found) {
        cur = urls[0]
      }
    }
    uni.previewImage({
      urls: urls,
      current: cur,
    })
  }
</script>

