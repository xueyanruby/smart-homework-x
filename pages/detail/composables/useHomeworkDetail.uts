  d.imagePaths.splice(0, d.imagePaths.length)
  d.imagePaths.push(
    'https://lh3.googleusercontent.com/aida-public/AB6AXuDPQyiB9tg4Gh5eMAz2jHtfNDW1OL9jm6OV8jMEsO3mUyiB7bkQIRvzbQMGZjdDlrX_tzubEOIVpH6y9eEmk41tUfxCSfgT78y8_Ix_UAjVSnSAdm-zbUeLmBTrrOq-k37f8hjnmhUx_hmtsfddr8V9M_y_mc915VHcqgiseNmeKbGy1CDrIlIi0xfobq3989OtuDNEewuJOkJi4cvMUcjeLUvCKDuP73JnWAiIrDD3A3Vd_uBy527cYcinh75n7zZzJcmwg9cfZlp0',
  )
  d.imagePaths.push(
    'https://lh3.googleusercontent.com/aida-public/AB6AXuAfvgeUk3It2azLzFftGbHSKIV2IX-97GtFvO9lfrxrE6e7ri37d3ipEasihGep5WcAI2-V-duwSEaL-Bt5L-FXLrw6BGNJfa11rJjavCT0kDImHfhLJX4cUs6_6RUtTW1RcX1Ri8JTxKLkAvgc99iD_7R2AQi8LVqV_kYbja1aKuxD_uLTj7ETdjQJJNoGFgs00MOIi-uEe90M0UCeEE2H-46xUQx2KNJy_CUtlH_pKoJp-SBNs7DunK2lR_a1pGZgZsHFF7ElVJSW',
