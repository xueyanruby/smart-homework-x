/** 作业详情：从本地存储加载任务，支持标记完成与删除 */

import { reactive, ref } from 'vue'
import {
  getTaskById,
  markDone,
  markUndone,
  deleteTask,
  taskIsDoneOnDayKey,
  type HomeworkTask,
} from '../../../shared/homeworkStore.uts'
import { dayKeyFromDate, parseChineseDateLabel, stripTime } from '../../../shared/homeworkDateUtils.uts'

type DetailFields = {
  statusLabel: string
  subjectTag: string
  title: string
  dateRangeLine: string
  descriptionTitle: string
  descriptionBody: string
  imagePaths: string[]
  repeatTitle: string
  repeatSub: string
}

function subjectTagFor(kind : string, customName : string) : string {
  if (kind == 'custom') {
    const t = customName != null ? customName.trim() : ''
    return t.length > 0 ? t : '其他'
  }
  if (kind == 'math') return '数学'
  if (kind == 'en') return '英语'
  if (kind == 'zh') return '语文'
  return '其他'
}

// Stitch 演示稿兜底（store 中找不到 taskKey 时显示）
